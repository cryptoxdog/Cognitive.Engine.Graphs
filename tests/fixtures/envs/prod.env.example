# CEG Production Environment Template — REPLACE ALL VALUES BEFORE USE
# Source: engine/config/settings.py:_validate_production_secrets()
# WARNING: Default secrets will be REJECTED when L9_ENV=prod

NEO4J_URI=bolt+s://your-neo4j-host:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=<REPLACE_WITH_SECURE_PASSWORD>
NEO4J_DATABASE=neo4j
NEO4J_POOL_SIZE=100
NEO4J_MAX_CONNECTION_LIFETIME=3600
NEO4J_CONNECTION_ACQUISITION_TIMEOUT=60

REDIS_URL=redis://:password@your-redis-host:6379/0

API_KEY=<REPLACE_WITH_SHA256_SECURE_KEY>
API_PORT=8000
API_WORKERS=8

L9_ENV=prod
L9_PROJECT=l9-engine

DOMAINS_ROOT=/app/domains
LOG_LEVEL=INFO

NEO4J_CIRCUIT_THRESHOLD=5
NEO4J_CIRCUIT_COOLDOWN=30.0
NEO4J_CIRCUIT_HALF_OPEN_MAX=3
