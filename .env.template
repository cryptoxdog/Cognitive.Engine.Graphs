# L9 Graph Cognitive Engine — Environment Template
# Copy to .env and fill in real values. Never commit .env to source control.

# --- Project Identity ---
L9_PROJECT=l9-engine
L9_ENV=dev

# --- Neo4j ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=change-me-in-production
NEO4J_DATABASE=neo4j
NEO4J_POOL_SIZE=50

# --- PostgreSQL (Audit Persistence) ---
# FIX(GAP-5): Required for compliance audit pool (shared/audit_persistence.py).
# Format: postgresql://user:password@host:port/dbname
# In production: populate from secrets manager (Vault, AWS Secrets Manager, etc.)
POSTGRES_DSN=postgresql://l9:change-me-in-production@localhost:5432/l9_audit

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- API ---
API_PORT=8000
API_WORKERS=4
API_SECRET_KEY=change-me-in-production

# --- Domain Packs ---
DOMAINS_ROOT=./domains

# --- Logging ---
LOG_LEVEL=INFO

# --- GDS ---
GDS_ENABLED=true
GDS_MAX_STALENESS_HOURS=25

# --- Tenant Auth ---
TENANT_AUTH_ENABLED=true
TENANT_AUTH_BYPASS_KEY=
CAPABILITY_AUTH_ENABLED=true
TENANT_ALLOWLIST=

# --- Scoring Defaults ---
W_STRUCTURAL=0.30
W_GEO=0.25
W_REINFORCEMENT=0.20
W_FRESHNESS=0.10
GEO_DECAY_KM=800.0

# --- KGE (Phase 4) ---
KGE_ENABLED=false
KGE_EMBEDDING_DIM=256
KGE_CONFIDENCE_THRESHOLD=0.3

# --- Pareto ---
PARETO_ENABLED=true
PARETO_N_SAMPLES=50

# --- Compliance / Audit ---
COMPLIANCE_FLUSH_INTERVAL=60
COMPLIANCE_BUFFER_MAX=100

# --- Wave 1 Hardening ---
DOMAIN_STRICT_VALIDATION=true
SCORE_CLAMP_ENABLED=true
STRICT_NULL_GATES=true
MAX_HOP_HARD_CAP=10
PARAM_STRICT_MODE=true
