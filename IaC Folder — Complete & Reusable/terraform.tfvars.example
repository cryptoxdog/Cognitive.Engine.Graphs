# ============================================================================
# L9 TERRAFORM VARIABLES — Copy to terraform.tfvars and customize
# ============================================================================
# Only override what differs from defaults. Everything else just works.
# ============================================================================

# --- Required ---
project   = "l9-engine"
env       = "dev"
api_image = "123456789.dkr.ecr.us-east-1.amazonaws.com/l9-engine:latest"

# --- Optional Overrides ---
# region             = "us-east-1"
# api_cpu            = 512
# api_memory         = 1024
# api_desired_count  = 2
# api_workers        = 4
# neo4j_cpu          = 2048
# neo4j_memory       = 8192
# neo4j_volume_size  = 100
# neo4j_gds_enabled  = true
# redis_node_type    = "cache.t3.micro"
# alarm_email        = "ops@yourcompany.com"
# log_level          = "INFO"
# cors_origins       = "*"

# --- Production Example ---
# env               = "prod"
# api_desired_count = 4
# api_min_count     = 2
# api_max_count     = 20
# api_cpu           = 1024
# api_memory        = 2048
# neo4j_cpu         = 4096
# neo4j_memory      = 16384
# neo4j_volume_size = 500
# redis_node_type   = "cache.r6g.large"
# log_retention_days = 90
# alarm_email       = "ops@yourcompany.com"
# log_level         = "WARNING"
