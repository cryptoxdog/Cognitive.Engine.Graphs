{
  "_l9_meta": {
    "l9_schema": 1,
    "origin": "l9-template",
    "engine": "graph",
    "layer": [
      "telemetry"
    ],
    "tags": [
      "L9_TEMPLATE",
      "telemetry",
      "grafana"
    ],
    "owner": "platform",
    "status": "active"
  },
  "dashboard": {
    "id": null,
    "uid": "l9-api",
    "title": "L9 Engine \u2014 API Performance",
    "tags": [
      "l9",
      "api"
    ],
    "timezone": "browser",
    "refresh": "15s",
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "panels": [
      {
        "id": 1,
        "type": "timeseries",
        "title": "Match Query Latency",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 0
        },
        "targets": [
          {
            "expr": "histogram_quantile(0.50, rate(l9_match_duration_seconds_bucket[5m])) * 1000",
            "legendFormat": "p50"
          },
          {
            "expr": "histogram_quantile(0.95, rate(l9_match_duration_seconds_bucket[5m])) * 1000",
            "legendFormat": "p95"
          },
          {
            "expr": "histogram_quantile(0.99, rate(l9_match_duration_seconds_bucket[5m])) * 1000",
            "legendFormat": "p99"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "ms"
          }
        }
      },
      {
        "id": 2,
        "type": "timeseries",
        "title": "Sync Throughput",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 0
        },
        "targets": [
          {
            "expr": "rate(l9_sync_entities_total[5m])",
            "legendFormat": "{{entity_type}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "ops"
          }
        }
      },
      {
        "id": 3,
        "type": "timeseries",
        "title": "Requests by Domain",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 8
        },
        "targets": [
          {
            "expr": "rate(l9_requests_total[5m])",
            "legendFormat": "{{domain}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "reqps"
          }
        }
      },
      {
        "id": 4,
        "type": "timeseries",
        "title": "Gate Compilation Time",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 8
        },
        "targets": [
          {
            "expr": "l9_gate_compile_duration_seconds * 1000",
            "legendFormat": "{{domain}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "ms"
          }
        }
      },
      {
        "id": 5,
        "type": "bargauge",
        "title": "Candidates Returned (avg)",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 16
        },
        "targets": [
          {
            "expr": "avg(l9_match_candidates_returned) by (domain)",
            "legendFormat": "{{domain}}"
          }
        ]
      },
      {
        "id": 6,
        "type": "timeseries",
        "title": "HTTP Status Codes",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 16
        },
        "targets": [
          {
            "expr": "rate(l9_requests_total[5m])",
            "legendFormat": "{{status}}"
          }
        ]
      }
    ]
  }
}
