{
  "dashboard": {
    "id": null,
    "uid": "l9-neo4j",
    "title": "L9 Engine \u2014 Neo4j",
    "tags": [
      "l9",
      "neo4j"
    ],
    "timezone": "browser",
    "refresh": "30s",
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "panels": [
      {
        "id": 1,
        "type": "gauge",
        "title": "Heap Used",
        "gridPos": {
          "h": 6,
          "w": 8,
          "x": 0,
          "y": 0
        },
        "targets": [
          {
            "expr": "neo4j_dbms_vm_heap_used / neo4j_dbms_vm_heap_committed * 100"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "max": 100,
            "thresholds": {
              "steps": [
                {
                  "color": "green",
                  "value": null
                },
                {
                  "color": "yellow",
                  "value": 70
                },
                {
                  "color": "red",
                  "value": 90
                }
              ]
            }
          }
        }
      },
      {
        "id": 2,
        "type": "gauge",
        "title": "Page Cache Hit Ratio",
        "gridPos": {
          "h": 6,
          "w": 8,
          "x": 8,
          "y": 0
        },
        "targets": [
          {
            "expr": "rate(neo4j_page_cache_hits_total[5m]) / (rate(neo4j_page_cache_hits_total[5m]) + rate(neo4j_page_cache_faults_total[5m])) * 100"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "max": 100,
            "thresholds": {
              "steps": [
                {
                  "color": "red",
                  "value": null
                },
                {
                  "color": "yellow",
                  "value": 80
                },
                {
                  "color": "green",
                  "value": 95
                }
              ]
            }
          }
        }
      },
      {
        "id": 3,
        "type": "stat",
        "title": "Store Size",
        "gridPos": {
          "h": 6,
          "w": 8,
          "x": 16,
          "y": 0
        },
        "targets": [
          {
            "expr": "neo4j_store_size_total"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "bytes"
          }
        }
      },
      {
        "id": 4,
        "type": "timeseries",
        "title": "Bolt Connections",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 6
        },
        "targets": [
          {
            "expr": "neo4j_bolt_connections_opened_total",
            "legendFormat": "opened"
          },
          {
            "expr": "neo4j_bolt_connections_closed_total",
            "legendFormat": "closed"
          },
          {
            "expr": "neo4j_bolt_connections_running",
            "legendFormat": "running"
          }
        ]
      },
      {
        "id": 5,
        "type": "timeseries",
        "title": "Transaction Rate",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 6
        },
        "targets": [
          {
            "expr": "rate(neo4j_transaction_committed_total[5m])",
            "legendFormat": "committed"
          },
          {
            "expr": "rate(neo4j_transaction_rollbacks_total[5m])",
            "legendFormat": "rollbacks"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "ops"
          }
        }
      },
      {
        "id": 6,
        "type": "timeseries",
        "title": "Query Execution Time",
        "gridPos": {
          "h": 8,
          "w": 24,
          "x": 0,
          "y": 14
        },
        "targets": [
          {
            "expr": "rate(neo4j_db_query_execution_latency_millis_sum[5m]) / rate(neo4j_db_query_execution_latency_millis_count[5m])",
            "legendFormat": "avg query time"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "ms"
          }
        }
      }
    ]
  }
}
