{
  "_l9_meta": {
    "l9_schema": 1,
    "origin": "l9-template",
    "engine": "graph",
    "layer": [
      "telemetry"
    ],
    "tags": [
      "L9_TEMPLATE",
      "telemetry",
      "grafana"
    ],
    "owner": "platform",
    "status": "active"
  },
  "dashboard": {
    "id": null,
    "uid": "l9-overview",
    "title": "L9 Engine \u2014 Overview",
    "tags": [
      "l9",
      "overview"
    ],
    "timezone": "browser",
    "refresh": "30s",
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "panels": [
      {
        "id": 1,
        "type": "stat",
        "title": "API Uptime",
        "gridPos": {
          "h": 4,
          "w": 6,
          "x": 0,
          "y": 0
        },
        "targets": [
          {
            "expr": "up{job=\"l9-api\"}",
            "legendFormat": "API"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "mappings": [
              {
                "type": "value",
                "options": {
                  "1": {
                    "text": "UP",
                    "color": "green"
                  },
                  "0": {
                    "text": "DOWN",
                    "color": "red"
                  }
                }
              }
            ]
          }
        }
      },
      {
        "id": 2,
        "type": "stat",
        "title": "Neo4j Uptime",
        "gridPos": {
          "h": 4,
          "w": 6,
          "x": 6,
          "y": 0
        },
        "targets": [
          {
            "expr": "up{job=\"neo4j\"}",
            "legendFormat": "Neo4j"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "mappings": [
              {
                "type": "value",
                "options": {
                  "1": {
                    "text": "UP",
                    "color": "green"
                  },
                  "0": {
                    "text": "DOWN",
                    "color": "red"
                  }
                }
              }
            ]
          }
        }
      },
      {
        "id": 3,
        "type": "gauge",
        "title": "Match p95 Latency (ms)",
        "gridPos": {
          "h": 4,
          "w": 6,
          "x": 12,
          "y": 0
        },
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(l9_match_duration_seconds_bucket[5m])) * 1000"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "steps": [
                {
                  "color": "green",
                  "value": null
                },
                {
                  "color": "yellow",
                  "value": 200
                },
                {
                  "color": "red",
                  "value": 500
                }
              ]
            },
            "unit": "ms",
            "max": 1000
          }
        }
      },
      {
        "id": 4,
        "type": "stat",
        "title": "Requests/sec",
        "gridPos": {
          "h": 4,
          "w": 6,
          "x": 18,
          "y": 0
        },
        "targets": [
          {
            "expr": "rate(l9_requests_total[1m])"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "reqps"
          }
        }
      },
      {
        "id": 5,
        "type": "timeseries",
        "title": "Request Rate by Endpoint",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 4
        },
        "targets": [
          {
            "expr": "rate(l9_requests_total[5m])",
            "legendFormat": "{{method}} {{endpoint}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "reqps"
          }
        }
      },
      {
        "id": 6,
        "type": "timeseries",
        "title": "Latency Distribution",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 4
        },
        "targets": [
          {
            "expr": "histogram_quantile(0.50, rate(l9_match_duration_seconds_bucket[5m])) * 1000",
            "legendFormat": "p50"
          },
          {
            "expr": "histogram_quantile(0.95, rate(l9_match_duration_seconds_bucket[5m])) * 1000",
            "legendFormat": "p95"
          },
          {
            "expr": "histogram_quantile(0.99, rate(l9_match_duration_seconds_bucket[5m])) * 1000",
            "legendFormat": "p99"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "ms"
          }
        }
      },
      {
        "id": 7,
        "type": "timeseries",
        "title": "Error Rate",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 12
        },
        "targets": [
          {
            "expr": "rate(l9_errors_total[5m])",
            "legendFormat": "{{error_type}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "color": {
              "mode": "fixed",
              "fixedColor": "red"
            }
          }
        }
      },
      {
        "id": 8,
        "type": "timeseries",
        "title": "Active Connections",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 12
        },
        "targets": [
          {
            "expr": "l9_neo4j_pool_active",
            "legendFormat": "Neo4j Active"
          },
          {
            "expr": "l9_neo4j_pool_idle",
            "legendFormat": "Neo4j Idle"
          },
          {
            "expr": "l9_redis_connections",
            "legendFormat": "Redis"
          }
        ]
      }
    ]
  }
}
