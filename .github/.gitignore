# Ignore temporary files and local environment configs in .github/
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Local environment configurations (don't commit filled-in values)
env.local
*.env.local

# Temporary files
*.tmp
*.bak
*~
